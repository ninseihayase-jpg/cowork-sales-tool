# ===== テーマDB連携（既存 秘書/Hisho の Render API）=====
# DBへの書き込み・読み取りに使う。秘書プロジェクトの debug API と同じ値。
THEME_API_URL=https://hisho-ohxe.onrender.com
# 実トークンはこのファイルでなく .env（.gitignore済み）に記入する。秘書プロジェクトのdebug API tokenと同じ値。
THEME_API_TOKEN=（ここに実トークンを入れる・コミットしない）

# ===== Google Sheets 連携（フェーズ1）=====
# 入力スプレッドシートのID（URLの /d/ と /edit の間の文字列）
SALES_SHEET_ID=
# サービスアカウント鍵JSONのパス（このファイルは .gitignore 済み・コミットしない）
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
# 入力ワークシート名（Sales分 / Sales以外分）。カンマ区切りで複数可。
SALES_WORKSHEETS=Sales,Sales以外
